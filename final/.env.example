# Crawlbase Normal token. Powers both the Crawler queue and the Crawling API.
# Create an account and copy your token from https://crawlbase.com/signup?signup=blog
CRAWLBASE_TOKEN=your_normal_token_here

# Name of the managed Crawler queue the engine creates and pushes into.
CRAWLER_NAME=distributed-engine

# Public URL Crawlbase POSTs each crawl result to. During local development
# expose the server with a tunnel (ngrok, cloudflared) and point this at /webhook.
CALLBACK_URL=https://your-public-host.example.com/webhook

# Local port the webhook server listens on.
PORT=3000

# Recursive crawl controls.
# MAX_DEPTH caps how far the engine follows discovered links (0 = seeds only).
MAX_DEPTH=2
# Restrict expansion to these domains so the crawl stays scoped. Comma-separated.
ALLOWED_DOMAINS=example.com

# Comma-separated seed URLs pushed by `npm run seed`.
SEED_URLS=https://example.com
